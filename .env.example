# sidearm — required secrets and config for docker compose.
# Copy to `.env` and fill in. Never commit the real .env.

# ---- CS2 -----------------------------------------------------------------

# Get one at https://steamcommunity.com/dev/managegameservers (app id 730).
# Rotating this value requires `docker compose up -d --force-recreate cs2`
# because it's passed as a launch argument, not a hot-reloadable cvar.
GSLT=

# Public server password (empty = open server).
SERVER_PASSWORD=

# RCON admin password. Only reachable from the internal docker network.
RCON_PASSWORD=change-me-to-a-long-random-string

# Cosmetic defaults — overridable from the UI once the panel is up.
SERVER_NAME=sidearm
CS2_MAXPLAYERS=10
CS2_GAMETYPE=0
CS2_GAMEMODE=1
CS2_MAPGROUP=mg_active
CS2_STARTMAP=de_mirage

# ---- Panel ---------------------------------------------------------------

# Shared secret embedded in the CS2 `logaddress_add_http` URL so the panel
# can reject spoofed log POSTs. Generate with: `openssl rand -hex 24`.
LOG_INGEST_SECRET=change-me

# Bearer token required on /api/* once auth lands (Phase G). Leave empty
# during Phase A–F to keep the demo open on a trusted network.
PANEL_ADMIN_TOKEN=
